modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Tunnel"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && yarn dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Tunnel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "yarn install --ignore-scripts && npx --yes patch-package && (ls node_modules/react-native-screens/package.json 2>/dev/null || (curl -sLo /tmp/rns.tgz https://registry.npmjs.org/react-native-screens/-/react-native-screens-4.16.0.tgz && tar -xzf /tmp/rns.tgz -C /tmp && cp -r /tmp/package node_modules/react-native-screens)) && node scripts/start-tunnel-share.mjs"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && node dist/server.js"]
build = ["bash", "-c", "cd backend && yarn install && yarn build"]
