{
  "name": "claw-code-mobile",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:lan": "TUNNEL=false node scripts/dev.mjs",
    "dev:tunnel": "node scripts/dev-tunnel.mjs",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:clear": "expo start --tunnel --clear",
    "start:tunnel:share": "expo start --tunnel --clear --port 8081",
    "start:tunnel:share:clear": "expo start --tunnel --clear --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "deploy:ios": "npx testflight",
    "deploy:web": "expo export -p web && npx eas-cli@latest deploy",
    "rebundle": "npx expo run:ios --configuration Release --unstable-rebundle --no-bundler",
    "prepare": "npx --yes patch-package",
    "test": "npm --prefix backend run test && cd backend && node --test --import tsx --test-reporter=spec ../utils/markdownCleanup.test.ts",
    "test:live": "npm --prefix backend run test:live"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.72",
    "@bacons/apple-colors": "^0.0.8",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "ai": "^6.0.168",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "^55.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~8.0.11",
    "expo-quick-actions": "^4.0.2",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "mapkit-react": "^1.15.3",
    "react": "19.1.6",
    "react-dom": "19.1.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/apple-mapkit-js-browser": "^5.65.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "postcss": "^8.5.1",
    "react-server-dom-webpack": "19.1.6",
    "tailwindcss": "^3.0.0",
