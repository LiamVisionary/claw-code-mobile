{
  "expo": {
    "name": "Claw Code Mobile",
    "slug": "claw-code-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icons/bouquet.png",
    "scheme": "clawcodemobile",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#000",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/bouquet.png",
      "resizeMode": "cover",
      "backgroundColor": "#000"
    },
    "ios": {
      "appleTeamId": "L7XLLTV3X7",
      "bundleIdentifier": "com.liamvisionary.clawcodemobile",
      "icon": {
        "light": "./assets/icons/bouquet.png",
        "dark": "./assets/icons/floral.png"
      },
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@bacons/apple-colors",
      [
        "expo-router",
        {}
      ],
      "expo-font",
      [
        "expo-quick-actions/icon/plugin",
        [
          "./assets/icons/scifi.png",
          "./assets/icons/awe.png",
          "./assets/icons/water.png",
          "./assets/icons/coffee.png",
          "./assets/icons/sunrise.png"
        ]
      ],
      "expo-quick-actions",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/bouquet.png",
          "resizeMode": "cover",
          "backgroundColor": "#000"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactServerFunctions": true
    },
    "extra": {}
  }
}
