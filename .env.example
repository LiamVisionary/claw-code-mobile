# ──────────────────────────────────────────────────────────────────────────
# Claw Code Mobile — environment variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in whatever you need. Everything here
# is OPTIONAL — `npm run dev` works with zero configuration on LAN.
#
# The dev-tunnel script auto-loads this file, so you don't have to export
# anything manually.
# ──────────────────────────────────────────────────────────────────────────


# ── Backend gateway ───────────────────────────────────────────────────────

# Bearer token the mobile app sends to authenticate with the backend.
# Must match on both sides. Default if unset: "dev-token".
GATEWAY_AUTH_TOKEN=dev-token

# Backend port. Default: 5000.
# PORT=5000


# ── Expo (only needed for remote / tunnel mode) ───────────────────────────

# Required when running Expo on a headless server so the CLI can fetch
# your EAS Update channel config without prompting. Generate one at:
#   https://expo.dev/accounts/[you]/settings/access-tokens
# Each developer creates their own — do NOT share.
#
# Without this, dev-tunnel falls back to `--offline` mode which skips
# manifest signing and EAS Update metadata. That works for most cases,
# but setting EXPO_TOKEN is the clean fix.
EXPO_TOKEN=


# ── Tunnel provider (dev-tunnel only) ─────────────────────────────────────

# Which tunnel provider to use: "cloudflared" (default) or "ngrok".
# cloudflared needs no account; ngrok needs an authtoken (free tier is fine).
TUNNEL_PROVIDER=cloudflared

# Ngrok authtoken — required if TUNNEL_PROVIDER=ngrok.
# Free signup: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=


# ── Telegram notifications (optional) ─────────────────────────────────────
# If both are set, dev-tunnel will DM you the Expo Go URL + backend URL +
# token automatically whenever a tunnel starts. Handy for headless dev.
#
# Create a bot: message @BotFather → /newbot → copy the token.
# Get your chat id: message your bot once, then fetch
#   https://api.telegram.org/bot<token>/getUpdates
# and look for `chat.id` in the JSON response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
