# https://www.weatherapi.com/my/ -- https://www.weatherapi.com/
WEATHER_API_KEY=xxx

# LLM provider: openai or openrouter
AI_PROVIDER=openai
# Example OpenAI model: gpt-4o-mini-2024-07-18
# Example OpenRouter model: openai/gpt-4o-mini
AI_MODEL=gpt-4o-mini-2024-07-18

OPENAI_API_KEY=sk-xxx

# https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-xxx
# Optional but recommended for OpenRouter analytics/routing
OPENROUTER_SITE_URL=https://your-app-url.example
OPENROUTER_APP_NAME=Claw Code Mobile

TMDB_READ_ACCESS_TOKEN=xxx

TMDB_API_KEY=xxx

# https://console.cloud.google.com/google/maps-apis/home;onboard=true?project=metro-cache
GOOGLE_MAPS_API_KEY=xxx

# https://developer.apple.com/account/resources/services/maps-tokens
EXPO_PUBLIC_APPLE_MAPKIT_JS_KEY=xxx

EXPO_UNSTABLE_DEPLOY_SERVER=1

# Optional: auto-share Expo tunnel links from start:tunnel:share
# Telegram (recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
